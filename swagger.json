{
  "openapi": "3.0.0",
  "info": {
    "title": "API AGROTECH",
    "version": "1.0.0",
    "description": "Documentação da API AGROTECH"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor local"
    }
  ],
  "securityDefinitions": {
    "bearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Bearer token para autenticação",
      "scheme": "bearer",
      "bearer format": "JWT",
      "bearer token": "JWT <token>",
      "bearer token description": "Bearer token para autenticação"
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearer format": "JWT"
      }
    }
  },
  "tags": [
    {
      "name": "Auth",
      "description": "Endpoints de autenticação"
    },
    {
      "name": "Arquivos Estáticos (imagens)",
      "description": "Endpoints de arquivos estáticos (imagens)"
    },
    {
      "name": "CRUD de Funcionários",
      "description": "Endpoints de CRUD de funcionários"
    },
    {
      "name": "CRUD de Animais e Manejo",
      "description": "Endpoints de CRUD de animais e manejo"
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "summary": "Login do usuário",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "description": "Dados de login, ao validar os dados de acesso emite um token que expira em 1 hora.",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "marcos@email.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "senha123"
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login bem-sucedido"
          },
          "400": {
            "description": "Erro de validação"
          }
        }
      }
    },
    "/static/{arquivo}": {
      "get": {
        "summary": "Diretório de arquivos estáticos (imagens)",
        "tags": [
          "Arquivos Estáticos (imagens)"
        ],
        "parameters": [
          {
            "name": "arquivo",
            "in": "path",
            "required": true,
            "description": "nome e extensão do arquivo",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Sucesso"
          },
          "401": {
            "description": "Não autorizado"
          },
          "404": {
            "description": "Não encontrado"
          }
        }
      }
    },
    "/imgs": {
      "post": {
        "summary": "Envio de imagens para diretório",
        "tags": [
          "Arquivos Estáticos (imagens)"
        ],
        "requestBody": {
          "description": "Dados de criação",
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "imagem": {
                    "type": "string",
                    "format": "binary"
                  }
                },
                "required": [
                  "imagem"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sucesso"
          },
          "400": {
            "description": "Erro de envio de dados"
          }
        }
      }
    },
    "/users": {
      "get": {
        "summary": "Obter lista de funcionários",
        "tags": [
          "CRUD de Funcionários"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Sucesso"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      },
      "post": {
        "summary": "Criar novo elemento",
        "tags": [
          "CRUD de Funcionários"
        ],
        "requestBody": {
          "description": "Dados de criação",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": {
                    "type": "string",
                    "example":"Ana Silva"
                  },
                  "email": {
                    "type": "string",
                    "example":"ana@silva.com"
                  },
                  "password": {
                    "type": "string",
                    "example":"senha123"
                  }
                },
                "required": [
                  "nome",
                  "email",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Criado com sucesso"
          },
          "400": {
            "description": "Erro de envio de dados"
          }
        }
      }
    },
    "/users/{id}": {
      "patch": {
        "summary": "Alterar elemento",
        "tags": [
          "CRUD de Funcionários"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID do funcionário que deve ser alterado",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Dados para alteração",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                },
                "required": []
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dados alterados com sucesso"
          },
          "404": {
            "description": "Dados não encontrados"
          }
        }
      },
      "delete": {
        "summary": "Excluir elemento",
        "tags": [
          "CRUD de Funcionários"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID do funcionário que deve ser removido",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Excluído com sucesso"
          },
          "400": {
            "description": "Erro ao excluir"
          },
          "404": {
            "description": "Id não encontrado"
          }
        }
      }
    },
    "/animais": {
      "get": {
        "summary": "Obter lista de animais",
        "tags": [
          "CRUD de Animais e Manejo"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Sucesso"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      },
      "post": {
        "summary": "Criar novo elemento",
        "tags": [
          "CRUD de Animais e Manejo"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "description": "Dados de criação",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "tipo": {
                    "type": "string",
                    "example": "Bovino"
                  },
                  "nome": {
                    "type": "string",
                    "example": "Bruto"
                  },
                  "sexo": {
                    "type": "string",
                    "example": "macho"
                  },
                  "peso": {
                    "type": "number",
                    "example": 150
                  },
                  "idade": {
                    "type": "number",
                    "example": 1.3
                  },
                  "abate": {
                    "type": "number",
                    "example": 2.2
                  },
                  "raca": {
                    "type": "string",
                    "example": "Nelore"
                  },
                  "lote": {
                    "type": "integer",
                    "example": 603
                  },
                  "imagem": {
                    "type": "string",
                    "example": "1729798538466.jpg"
                  }
                },
                "required": [
                  "tipo",
                  "nome",
                  "sexo",
                  "peso",
                  "idade",
                  "abate",
                  "raca",
                  "lote"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Criado com sucesso"
          },
          "400": {
            "description": "Erro de envio de dados"
          }
        }
      }
    },
    "/animais/{id}": {
      "patch": {
        "summary": "Alterar elemento",
        "tags": [
          "CRUD de Animais e Manejo"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID do animal que deve ser alterado",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Dados para alteração",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "tipo": {
                    "type": "string",
                    "example": "Bovino"
                  },
                  "nome": {
                    "type": "string",
                    "example": "Bruto"
                  },
                  "sexo": {
                    "type": "string",
                    "example": "macho"
                  },
                  "peso": {
                    "type": "number",
                    "example": 150
                  },
                  "idade": {
                    "type": "number",
                    "example": 1.3
                  },
                  "abate": {
                    "type": "number",
                    "example": 2.2
                  },
                  "raca": {
                    "type": "string",
                    "example": "Nelore"
                  },
                  "lote": {
                    "type": "integer",
                    "example": 603
                  },
                  "imagem": {
                    "type": "string",
                    "example": "1729798538466.jpg"
                  }
                },
                "required": []
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dados alterados com sucesso"
          },
          "404": {
            "description": "Dados não encontrados"
          }
        }
      },
      "delete": {
        "summary": "Excluir elemento",
        "tags": [
          "CRUD de Animais e Manejo"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID do animal que deve ser removido",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Excluído com sucesso"
          },
          "400": {
            "description": "Id não encontrado"
          }
        }
      }
    }
  }
}